TLDV_API_KEY=your_tldv_api_key_here
# 省略時は https://pasta.tldv.io（公式ドキュメントの本番エンドポイント）
# TLDV_BASE_URL=https://pasta.tldv.io
# ローカル図解テスト用（scripts/render_from_tldv_meeting.py を引数なしで実行するとき）
# TLDV_TEST_MEETING_ID=your_meeting_uuid_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0000000000
# Bot をチャンネルに招待したうえで、files:write / chat:write 等を付与
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
# ボード URL が https://trello.com/b/AbCdEfGh/... なら AbCdEfGh または URL 全文でも可（show_trello_lists が解釈）
TRELLO_BOARD_ID=your_trello_board_id_here
TRELLO_LIST_ID=your_trello_list_id_here
# LIST_ID は「リスト」の ID（ボード ID ではない）。404 のときは scripts/show_trello_lists.py で確認
# 特定の担当だけカード化（カンマ区切り・未設定なら全員）。例: 高橋圭佑,高橋
# TRELLO_ASSIGNEE_FILTER=高橋圭佑,高橋
# true / 1 のとき Trello にカードを作らず Slack まで実行（結合テスト用）
# PIPELINE_SKIP_TRELLO=true
# Webhook 認証: ?token= または X-Webhook-Secret / X-Webhook-Token / Authorization: Bearer …（WEBHOOK_SECRET と一致）
# 併用可: ヘッダー x-api-key が TLDV_API_KEY と一致しても通る（tl;dv の「APIキー」認証向け）
WEBHOOK_SECRET=change_me_to_a_random_string
LOG_LEVEL=INFO
# 要約 PNG のフォント（任意。未設定時は fonts/NotoSansJP-Regular.otf → GitHub から /tmp へ取得 → OS 候補の順）
# SUMMARY_FONT_PATH=/path/to/NotoSansJP-Regular.otf
# 見出し・KPI 用太字（任意。未設定時はヒラギノ W6 等を自動試行。Noto なら Bold を同フォルダに置くと自動検出）
# SUMMARY_FONT_BOLD_PATH=/path/to/NotoSansJP-Bold.otf
# 空にすると自動ダウンロードを無効化（オフラインのみ・同梱フォント必須）
# SUMMARY_FONT_DOWNLOAD_URL=
# 別 URL を指定する場合（既定は notofonts/noto-cjk の NotoSansCJKjp-Regular.otf）
# SUMMARY_FONT_DOWNLOAD_URL=https://example.com/NotoSansJP-Regular.otf
# --- Webhook 二重受信の防止（任意・Vercel 本番推奨）---
# Upstash Console の Redis で HTTPS の REST URL と Token をコピー
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxx
# DEDUPE_WEBHOOK_TTL_SECONDS=604800
# DEDUPE_MEETING_TTL_SECONDS=604800
# --- 要約 HTML の公開 URL（任意・Slack コメントに「ブラウザで開く」リンク）---
# GCS を設定すると S3 より優先（図解と同じ GOOGLE_APPLICATION_CREDENTIALS で可）
# MEETING_HTML_GCS_BUCKET=your-gcs-bucket-name
# MEETING_HTML_GCS_PREFIX=meetings
# --- 要約 HTML を S3 に置く場合（GCS 未設定時のみ）---
# MEETING_HTML_S3_BUCKET=your-s3-bucket-name
# MEETING_HTML_S3_PREFIX=meetings
# MEETING_HTML_S3_REGION=ap-northeast-1
# CloudFront 等のベース URL（末尾スラッシュなし）。GCS 時は storage.googleapis.com の代わりにこのベース＋キー
# MEETING_HTML_PUBLIC_BASE_URL=https://files.example.com
# ローカルから boto3 で S3 に put する場合（本番 Lambda 等では IAM ロールでも可）
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
#
# --- 図解 HTML: Google Cloud Storage ＋ Slack（任意）---
# scripts/generate_meeting_infographic_html.py で、バケット名が設定されているときだけ
# パスワード保護HTMLをアップロードし、公開URLとパスワードを Slack に投稿する。
# サービスアカウントに storage.objects.create が必要。オブジェクト／バケットは匿名読み取り可にする。
# INFOGRAPHIC_GCS_BUCKET=your-gcs-bucket-name
# INFOGRAPHIC_GCS_PREFIX=infographics
# 未設定時は SLACK_CHANNEL_ID と同じチャンネルへ投稿
# INFOGRAPHIC_SLACK_CHANNEL_ID=C0000000000
# 認証例: JSON キーのパス（ローカル）
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

