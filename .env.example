TLDV_API_KEY=your_tldv_api_key_here
# 省略時は https://pasta.tldv.io（公式ドキュメントの本番エンドポイント）
# TLDV_BASE_URL=https://pasta.tldv.io
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0000000000
# Bot をチャンネルに招待したうえで、files:write / chat:write 等を付与
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
# ボード URL が https://trello.com/b/AbCdEfGh/... なら AbCdEfGh または URL 全文でも可（show_trello_lists が解釈）
TRELLO_BOARD_ID=your_trello_board_id_here
TRELLO_LIST_ID=your_trello_list_id_here
# LIST_ID は「リスト」の ID（ボード ID ではない）。404 のときは scripts/show_trello_lists.py で確認
# 特定の担当だけカード化（カンマ区切り・未設定なら全員）。例: 高橋圭佑,高橋
# TRELLO_ASSIGNEE_FILTER=高橋圭佑,高橋
# Webhook 認証: ?token= または X-Webhook-Secret / X-Webhook-Token / Authorization: Bearer …（WEBHOOK_SECRET と一致）
# 併用可: ヘッダー x-api-key が TLDV_API_KEY と一致しても通る（tl;dv の「APIキー」認証向け）
WEBHOOK_SECRET=change_me_to_a_random_string
LOG_LEVEL=INFO
# 要約 PNG のフォント（任意。未設定なら macOS のヒラギノ等を自動検出）
# SUMMARY_FONT_PATH=/path/to/NotoSansJP-Regular.ttf
# --- Webhook 二重受信の防止（任意・Vercel 本番推奨）---
# Upstash Console の Redis で HTTPS の REST URL と Token をコピー
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxx
# DEDUPE_WEBHOOK_TTL_SECONDS=604800
# DEDUPE_MEETING_TTL_SECONDS=604800

